# ─────────────────────────────────────────────
#  INVESTMENT AGENT — ENVIRONMENT CONFIGURATION
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the .env file.

# ── LLM Provider ─────────────────────────────
# Primary LLM: "claude" | "openai" | "kimi" | "deepseek" | "none"
# If the primary fails, the agent auto-falls back through:
#   claude → kimi → deepseek → openai  (first with a key wins)
LLM_PROVIDER=claude

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── NVIDIA NIM (Kimi K2 + DeepSeek V3) ───────
# One key covers both models.
# Get key at: https://build.nvidia.com  →  Get API Key
NVIDIA_API_KEY=

# Kimi K2 (Moonshot AI) — strong reasoning, 128k context
KIMI_MODEL=moonshotai/kimi-k2.5

# DeepSeek V3.2 — with extended chain-of-thought thinking
DEEPSEEK_MODEL=deepseek-ai/deepseek-v3.2
# Set false to skip chain-of-thought (faster, lower token usage)
DEEPSEEK_THINKING=true

# ── Market Data APIs ──────────────────────────
# Alpha Vantage — free tier: 25 req/day
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# NewsAPI — free tier: 100 req/day
# Get key at: https://newsapi.org/register
NEWS_API_KEY=

# ── Broker APIs ───────────────────────────────
# Zerodha Kite
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Groww (when available)
GROWW_API_KEY=

# CAS Parser API (optional) for CDSL/NSDL sync + high-accuracy CAS parsing
# Sign up at https://casparser.in and set your API key
CAS_PARSER_API_KEY=
CAS_PARSER_BASE_URL=https://api.casparser.in

# ── Telegram Bot ─────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (get via @userinfobot)
TELEGRAM_CHAT_ID=

# ── Email (SMTP) ──────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
# For Gmail: use App Password (not your account password)
EMAIL_PASS=your_app_password
EMAIL_FROM="Investment Agent <your_email@gmail.com>"
EMAIL_TO=recipient@example.com

# ── WhatsApp ──────────────────────────────────
# Uses whatsapp-web.js (scan QR code on first run)
WHATSAPP_ENABLED=false
# Your WhatsApp number in international format (no + sign)
WHATSAPP_RECIPIENT=919876543210

# ── Notifications ─────────────────────────────
# Comma-separated: "telegram,email,whatsapp"
NOTIFICATION_CHANNELS=telegram,email

# ── Scheduler ─────────────────────────────────
# 24h format, IST (Asia/Kolkata)
MORNING_BRIEF_TIME=08:00
EVENING_BRIEF_TIME=20:00
TIMEZONE=Asia/Kolkata

# ── Storage ───────────────────────────────────
# Path to SQLite database file
DB_PATH=./data/portfolio.db

# Path for uploaded PDF/CSV files
UPLOADS_PATH=./uploads

# ── Logging ───────────────────────────────────
# "error" | "warn" | "info" | "debug"
LOG_LEVEL=info
LOGS_PATH=./logs
