{
  "name": "investment-agent",
  "version": "0.1.0",
  "description": "AI-powered portfolio analysis agent for Indian markets",
  "main": "index.js",
  "scripts": {
    "start": "concurrently -n agent,pwa -c cyan,magenta \"node index.js\" \"npm start --prefix pwa\"",
    "start:agent": "node index.js",
    "start:pwa": "npm start --prefix pwa",
    "dev": "concurrently -n agent,pwa -c cyan,magenta \"node --watch index.js\" \"npm start --prefix pwa\"",
    "setup": "node index.js setup",
    "portfolio": "node index.js portfolio",
    "goals": "node index.js goals",
    "brief:morning": "node index.js brief morning",
    "brief:evening": "node index.js brief evening",
    "analyze": "node index.js analyze",
    "status": "node index.js status",
    "notify:test": "node index.js notify test",
    "install:all": "npm install && npm install --prefix pwa",
    "rebuild": "PUPPETEER_SKIP_DOWNLOAD=true npm rebuild"
  },
  "config": {
    "puppeteer_skip_chromium_download": "true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.8.1",
    "chalk": "^4.1.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "inquirer": "^8.2.6",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "papaparse": "^5.4.1",
    "pdf-parse": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "rss-parser": "^3.13.0",
    "telegraf": "^4.16.3",
    "whatsapp-web.js": "^1.26.0",
    "winston": "^3.17.0",
    "xirr": "^1.0.4",
    "xlsx": "^0.18.5",
    "yahoo-finance2": "^2.13.3"
  },
  "keywords": [
    "investment",
    "portfolio",
    "stocks",
    "mutual-funds",
    "india",
    "NSE",
    "BSE"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
