# ─────────────────────────────────────────────
#  INVESTMENT AGENT — ENVIRONMENT CONFIGURATION
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the .env file.

# ── LLM Provider ─────────────────────────────
# Primary LLM: "claude" | "openai" | "none"
LLM_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (fallback / alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Market Data APIs ──────────────────────────
# Alpha Vantage — free tier: 25 req/day
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# NewsAPI — free tier: 100 req/day
# Get key at: https://newsapi.org/register
NEWS_API_KEY=

# ── Broker APIs ───────────────────────────────
# Zerodha Kite
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Groww (when available)
GROWW_API_KEY=

# ── Telegram Bot ─────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (get via @userinfobot)
TELEGRAM_CHAT_ID=

# ── Email (SMTP) ──────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
# For Gmail: use App Password (not your account password)
EMAIL_PASS=your_app_password
EMAIL_FROM="Investment Agent <your_email@gmail.com>"
EMAIL_TO=recipient@example.com

# ── WhatsApp ──────────────────────────────────
# Uses whatsapp-web.js (scan QR code on first run)
WHATSAPP_ENABLED=false
# Your WhatsApp number in international format (no + sign)
WHATSAPP_RECIPIENT=919876543210

# ── Notifications ─────────────────────────────
# Comma-separated: "telegram,email,whatsapp"
NOTIFICATION_CHANNELS=telegram,email

# ── Scheduler ─────────────────────────────────
# 24h format, IST (Asia/Kolkata)
MORNING_BRIEF_TIME=08:00
EVENING_BRIEF_TIME=20:00
TIMEZONE=Asia/Kolkata

# ── Storage ───────────────────────────────────
# Path to SQLite database file
DB_PATH=./data/portfolio.db

# Path for uploaded PDF/CSV files
UPLOADS_PATH=./uploads

# ── Logging ───────────────────────────────────
# "error" | "warn" | "info" | "debug"
LOG_LEVEL=info
LOGS_PATH=./logs
